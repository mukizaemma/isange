APP_NAME="Isange Paradise Resort"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://isangeparadiseresort.com

# Database, session, cache — set for your host

# --- Booking emails (Resend API — no server SMTP required) ---
# 1. Create account at https://resend.com
# 2. Verify domain isangeparadiseresort.com (DNS records in Resend dashboard)
# 3. Create API key and paste below
# 4. Use a FROM address on your verified domain
#
# Email flow (email channel only — WhatsApp bookings send no emails):
#   On submit  → hotel notification (MAIL_NOTIFICATION_TO) + guest acknowledgement (guest email)
#   On confirm → guest email with outcome: confirmed, unable to accommodate, rejected, or no-show
MAIL_MAILER=resend
RESEND_API_KEY=

MAIL_FROM_ADDRESS=bookings@isangeparadiseresort.com
MAIL_FROM_NAME="Isange Paradise Resort"

# Where booking requests are delivered (hotel inbox)
MAIL_NOTIFICATION_TO=info@isangeparadiseresort.com
# Optional copy for monitoring
MAIL_NOTIFICATION_CC=
